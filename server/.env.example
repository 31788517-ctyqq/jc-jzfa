# ============ 竞彩推荐监控 - 环境配置模板 ============
PORT=3000
NODE_ENV=production

# 第三方数据源凭证（必填）
MIDOU_BASE_URL=https://midou310.com/mdsj
MIDOU_MOBILE=your_mobile
MIDOU_PASSWORD=your_password

# CORS 允许域名（逗号分隔，生产环境改为实际域名）
ALLOWED_ORIGINS=http://localhost:3000

# 定时爬取配置
AUTO_CRAWL_ENABLED=false
AUTO_CRAWL_CRON=0 7 * * *

# ── 邮件告警配置 ──
# 告警总开关（false 禁用）
ALERT_ENABLED=true
# 收件人邮箱
ALERT_RECIPIENT=31788517@qq.com
# QQ邮箱 SMTP 配置（需在QQ邮箱设置中开启SMTP服务并获取授权码）
ALERT_SMTP_HOST=smtp.qq.com
ALERT_SMTP_PORT=465
ALERT_SMTP_USER=your_sender@qq.com
ALERT_SMTP_PASS=your_smtp_authorization_code
