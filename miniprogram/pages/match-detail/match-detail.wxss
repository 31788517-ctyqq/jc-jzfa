.detail-page {
  padding-top: 62rpx;
  padding-bottom: 168rpx;
}

.detail-title {
  max-width: 500rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
}

.match-header {
  min-height: 320rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(1, 10, 14, 0.36), rgba(1, 12, 18, 0.86)),
    url('/images/worldcup/pro/stadium_bg_01.png') center center / cover no-repeat,
    url('/images/worldcup/design-stadium-wide.jpg') center center / cover no-repeat;
}

.match-header::after {
  content: '';
  position: absolute;
  left: -8%;
  right: -8%;
  bottom: -28rpx;
  height: 124rpx;
  border-radius: 50% 50% 0 0;
  background: radial-gradient(ellipse at center, rgba(27, 244, 232, 0.25), rgba(23, 117, 87, 0.22) 42%, transparent 66%);
}

.header-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 70rpx;
}

.header-top-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.league {
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 800;
}

.score-area {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.team {
  flex: 1;
  color: #fff;
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
}

.score-txt {
  width: 100rpx;
  text-align: center;
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 900;
  text-transform: uppercase;
}

.match-time {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  color: rgba(255,255,255,0.74);
  font-size: 26rpx;
}

.merged-section {
  padding: 24rpx 24rpx 12rpx;
  overflow: hidden;
  background:
    linear-gradient(145deg, rgba(4, 28, 36, 0.88), rgba(1, 14, 20, 0.94)),
    url('/images/worldcup/pro/particle_teal.png') center top / cover no-repeat,
    url('/images/worldcup/pro/grid_hex.png') center bottom / cover no-repeat,
    url('/images/worldcup/design-grass-texture.jpg') center bottom / cover no-repeat;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 900;
  color: #fff;
}

.section-link {
  color: rgba(255,255,255,0.66);
  font-size: 24rpx;
}

.chart-container {
  width: 100%;
  height: 470rpx;
  box-sizing: border-box;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 22rpx;
  padding: 4rpx 0 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.07);
}

.legend-item {
  display: flex;
  align-items: center;
  color: rgba(255,255,255,0.78);
  font-size: 22rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  margin-right: 8rpx;
  border-radius: 50%;
}

.recomm-list {
  padding-top: 10rpx;
}

.recomm-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 4rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.recomm-item:last-child {
  border-bottom: 0;
}

.recomm-left {
  display: flex;
  align-items: baseline;
  gap: 22rpx;
}

.direction-name {
  font-size: 30rpx;
  font-weight: 900;
}

.expert-num {
  color: rgba(255,255,255,0.58);
  font-size: 26rpx;
  font-weight: 700;
}

.detail-float-tab {
  position: fixed;
  left: 34rpx;
  right: 34rpx;
  bottom: calc(34rpx + env(safe-area-inset-bottom));
  z-index: 10;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-radius: 58rpx;
  background: rgba(4, 29, 36, 0.88);
  border: 1rpx solid rgba(255,255,255,0.10);
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.42);
}

.detail-tab-item {
  width: 152rpx;
  height: 84rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-tab-item.active {
  background: radial-gradient(circle at 50% 48%, rgba(18, 241, 231, 0.25), rgba(18, 241, 231, 0.08) 58%, transparent 72%);
}

.detail-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  color: #fff;
}

.detail-tab-item.active .detail-icon {
  color: var(--color-primary);
}

.icon-home::before { content: ''; position: absolute; left: 5rpx; top: 17rpx; width: 30rpx; height: 22rpx; border: 4rpx solid currentColor; border-top: 0; border-radius: 3rpx; }
.icon-home::after { content: ''; position: absolute; left: 7rpx; top: 2rpx; width: 27rpx; height: 27rpx; border-left: 4rpx solid currentColor; border-top: 4rpx solid currentColor; transform: rotate(45deg); border-radius: 3rpx; }
.icon-home view { position: absolute; left: 18rpx; bottom: 3rpx; width: 7rpx; height: 14rpx; background: currentColor; border-radius: 4rpx 4rpx 0 0; }
.icon-ball { border: 4rpx solid currentColor; border-radius: 50%; box-sizing: border-box; }
.icon-ball::before { content: ''; position: absolute; left: 16rpx; top: 4rpx; width: 4rpx; height: 30rpx; background: currentColor; transform: rotate(28deg); }
.icon-ball::after { content: ''; position: absolute; left: 5rpx; top: 19rpx; width: 28rpx; height: 4rpx; background: currentColor; transform: rotate(-20deg); }
.icon-cup::before { content: ''; position: absolute; left: 11rpx; top: 4rpx; width: 20rpx; height: 24rpx; border: 4rpx solid currentColor; border-top-width: 6rpx; border-radius: 4rpx 4rpx 14rpx 14rpx; }
.icon-cup::after { content: ''; position: absolute; left: 18rpx; top: 30rpx; width: 7rpx; height: 10rpx; background: currentColor; }
.icon-cup view { position: absolute; left: 7rpx; bottom: 0; width: 28rpx; height: 4rpx; background: currentColor; border-radius: 5rpx; }
.icon-bars::before, .icon-bars::after, .icon-bars view { content: ''; position: absolute; bottom: 2rpx; width: 8rpx; border-radius: 8rpx; background: currentColor; }
.icon-bars::before { left: 4rpx; height: 22rpx; }
.icon-bars view { left: 17rpx; height: 34rpx; }
.icon-bars::after { right: 4rpx; height: 44rpx; }
