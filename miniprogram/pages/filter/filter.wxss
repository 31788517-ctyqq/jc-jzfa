.filter-page {
  padding-top: 72rpx;
}

/* ==================== 筛选条件区 ==================== */
.filter-section {
  padding: 28rpx 32rpx;
  margin-bottom: 26rpx;
}

.section-label {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 24rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.filter-row:last-of-type {
  border-bottom: none;
}

.filter-label {
  width: 120rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.78);
  flex-shrink: 0;
}

.filter-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.picker-value {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 600;
  max-width: 340rpx;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.direction-selector {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.direction-picker {
  justify-content: flex-start;
}

.direction-picker .picker-value {
  text-align: left;
}

/* 查询按钮 */
.filter-btn {
  margin-top: 20rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, rgba(18, 241, 231, 0.18), rgba(18, 241, 231, 0.38));
  border: 1rpx solid rgba(18, 241, 231, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 800;
  transition: all 0.2s;
}

.filter-btn:active {
  background: linear-gradient(135deg, rgba(18, 241, 231, 0.32), rgba(18, 241, 231, 0.54));
  transform: scale(0.97);
}

/* ==================== 结果摘要卡片 ==================== */
.result-card {
  position: relative;
  text-align: center;
  padding: 32rpx;
  margin-bottom: 26rpx;
  overflow: hidden;
}

.condition-summary {
  display: inline-block;
  padding: 10rpx 28rpx;
  background: rgba(18, 241, 231, 0.10);
  border: 1rpx solid rgba(18, 241, 231, 0.15);
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 28rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-stats {
  margin-bottom: 24rpx;
}

.result-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 12rpx;
}

.hit-num {
  font-size: 96rpx;
  font-weight: 900;
  color: var(--color-primary);
  text-shadow: 0 0 24rpx rgba(18, 241, 231, 0.36);
  line-height: 1;
}

.result-divider {
  font-size: 56rpx;
  font-weight: 300;
  color: rgba(255,255,255,0.36);
}

.total-num {
  font-size: 64rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.62);
  line-height: 1;
}

.result-labels {
  margin-top: 12rpx;
}

.result-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.50);
}

/* 命中率环形展示 */
.hit-rate-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.rate-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid;
}

.rate-circle.good {
  border-color: #4caf50;
  background: rgba(76, 175, 80, 0.08);
}

.rate-circle.normal {
  border-color: #ffb21c;
  background: rgba(255, 178, 28, 0.08);
}

.rate-circle.low {
  border-color: #ff2d35;
  background: rgba(255, 45, 53, 0.08);
}

.rate-val {
  font-size: 36rpx;
  font-weight: 900;
}

.rate-circle.good .rate-val { color: #4caf50; }
.rate-circle.normal .rate-val { color: #ffb21c; }
.rate-circle.low .rate-val { color: #ff2d35; }

.rate-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.62);
  font-weight: 600;
}

/* ==================== 详情列表 ==================== */
.detail-section {
  padding: 28rpx 30rpx;
  margin-bottom: 26rpx;
}

.block-title {
  display: block;
  margin-bottom: 22rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
}

.detail-scroll {
  max-height: 900rpx;
}

.detail-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.detail-num {
  font-size: 22rpx;
  color: rgba(255,255,255,0.50);
  background: rgba(255,255,255,0.06);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.detail-league {
  font-size: 22rpx;
  color: rgba(255,255,255,0.56);
}

.detail-result {
  margin-left: auto;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.detail-result.hit {
  color: #4caf50;
  background: rgba(76, 175, 80, 0.12);
}

.detail-result.miss {
  color: #ff2d35;
  background: rgba(255, 45, 53, 0.12);
}

.detail-main {
  margin-bottom: 8rpx;
}

.detail-teams {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-wrap: wrap;
}

.detail-date {
  font-size: 22rpx;
  color: rgba(255,255,255,0.44);
}

.detail-dir {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.detail-experts {
  font-size: 22rpx;
  color: rgba(255,255,255,0.50);
}

.detail-rank {
  font-size: 22rpx;
  color: #ffb21c;
  font-weight: 600;
}

/* ==================== 状态提示 ==================== */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-wrap {
  padding: 80rpx 0;
}

.hint-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 20rpx;
}

.hint-emoji {
  font-size: 80rpx;
}

.hint-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.50);
}
