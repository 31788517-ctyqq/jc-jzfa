.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ranking-card {
  position: relative;
  min-height: 218rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 24rpx;
  padding: 28rpx 30rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(1, 10, 14, 0.88), rgba(1, 12, 18, 0.64) 58%, rgba(1, 10, 14, 0.94)),
    url('/images/worldcup/pro/grid_hex.png') center center / cover no-repeat,
    url('/images/worldcup/design-light-card.jpg') center center / cover no-repeat;
  border: 1rpx solid rgba(64, 233, 227, 0.16);
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.28), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.rank-section {
  width: 82rpx;
  display: flex;
  justify-content: center;
  flex-shrink: 0;
}

.rank-badge {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  background: rgba(255, 255, 255, 0.13);
  box-shadow: 0 0 20rpx rgba(0, 0, 0, 0.28);
}

.rank-badge.top1 {
  width: 70rpx;
  height: 70rpx;
  color: #001018;
  background: linear-gradient(145deg, #ffd65c, #ffa42b);
}

.rank-badge.top2 {
  width: 66rpx;
  height: 66rpx;
  color: #102033;
  background: linear-gradient(145deg, #9bd1ff, #d5e9ff);
}

.rank-badge.top3 {
  width: 64rpx;
  height: 64rpx;
  color: #2d1300;
  background: linear-gradient(145deg, #ff8d41, #ffb06a);
}

.info-section {
  flex: 1;
  min-width: 0;
}

.teams {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.teams text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}

.teams .home,
.teams .away {
  max-width: 280rpx;
}

.vs {
  color: rgba(255, 255, 255, 0.82) !important;
  font-size: 24rpx !important;
  flex-shrink: 0;
}

.meta-line {
  display: block;
  margin-bottom: 18rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 24rpx;
}

.direction-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.category-label {
  color: #fff;
  margin-right: 10rpx;
}

.direction-label {
  font-weight: 900;
}

.expert-count {
  color: rgba(255,255,255,0.70);
}

.progress-bar {
  height: 8rpx;
  width: 100%;
  border-radius: 8rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.09);
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #15efe6, #50fff5);
  box-shadow: 0 0 16rpx rgba(18, 241, 231, 0.36);
}
