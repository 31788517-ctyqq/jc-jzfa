.match-card {
  position: relative;
  min-height: 344rpx;
  margin-bottom: 24rpx;
  padding: 28rpx 30rpx 24rpx;
  overflow: hidden;
  box-sizing: border-box;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(1, 10, 14, 0.42), rgba(1, 12, 18, 0.88)),
    url('/images/worldcup/pro/stadium_bg_02.png') center center / cover no-repeat,
    url('/images/worldcup/design-stadium-wide.jpg') center center / cover no-repeat;
  border: 1rpx solid rgba(64, 233, 227, 0.16);
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.28), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.match-card::after {
  content: '';
  position: absolute;
  right: -34rpx;
  bottom: -44rpx;
  width: 220rpx;
  height: 160rpx;
  border-radius: 50%;
  background:
    url('/images/worldcup/pro/football_glow.png') center center / cover no-repeat,
    radial-gradient(circle, rgba(255, 255, 255, 0.26) 0 10%, transparent 11% 100%),
    radial-gradient(circle, rgba(18, 241, 231, 0.11), transparent 65%);
  opacity: 0.65;
}

.round-pill,
.status-pill {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #12f1e7;
  background: rgba(18, 241, 231, 0.08);
  font-weight: 700;
  font-size: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 54rpx;
}

.league {
  color: #12f1e7;
  font-size: 25rpx;
  font-weight: 700;
}

.score-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 42rpx;
}

.team {
  flex: 1;
  min-width: 0;
  color: #fff;
  font-size: 36rpx;
  line-height: 1.15;
  font-weight: 800;
  text-align: center;
}

.team.long {
  font-size: 31rpx;
}

.score {
  width: 106rpx;
  text-align: center;
  color: #fff;
  font-size: 46rpx;
  line-height: 1;
  font-weight: 900;
  text-transform: uppercase;
  text-shadow: 0 0 18rpx rgba(255, 255, 255, 0.38);
}

.card-mid,
.card-footer {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-mid {
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.07);
}

.recomm-info {
  color: #12f1e7;
  font-size: 25rpx;
}

.match-time {
  color: rgba(255,255,255,0.86);
  font-size: 26rpx;
}

.card-footer {
  padding-top: 18rpx;
}

.clock-dot {
  width: 18rpx;
  height: 18rpx;
  margin-right: 9rpx;
  border: 3rpx solid #12f1e7;
  border-radius: 50%;
  box-sizing: border-box;
}
