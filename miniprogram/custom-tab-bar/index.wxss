.custom-tabbar {
  position: fixed;
  left: 34rpx;
  right: 34rpx;
  bottom: calc(34rpx + env(safe-area-inset-bottom));
  z-index: 999;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background:
    linear-gradient(180deg, rgba(4, 29, 36, 0.78), rgba(2, 18, 24, 0.92)),
    url('/images/worldcup/pro/tab_icon_default.png') center center / cover no-repeat;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 58rpx;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.42), inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(22rpx);
}

.tabbar-item {
  width: 152rpx;
  height: 84rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tabbar-item.active {
  background:
    radial-gradient(circle at 50% 48%, rgba(18, 241, 231, 0.28), rgba(18, 241, 231, 0.08) 58%, transparent 72%),
    url('/images/worldcup/pro/tab_icon_active.png') center center / cover no-repeat;
}

.tabbar-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  color: #fff;
  opacity: 0.95;
}

.tabbar-item.active .tabbar-icon {
  color: #12f1e7;
  opacity: 1;
}

.icon-home::before {
  content: '';
  position: absolute;
  left: 5rpx;
  top: 17rpx;
  width: 30rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 3rpx;
}

.icon-home::after {
  content: '';
  position: absolute;
  left: 7rpx;
  top: 2rpx;
  width: 27rpx;
  height: 27rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: rotate(45deg);
  border-radius: 3rpx;
}

.icon-home .icon-inner {
  position: absolute;
  left: 18rpx;
  bottom: 3rpx;
  width: 7rpx;
  height: 14rpx;
  background: currentColor;
  border-radius: 4rpx 4rpx 0 0;
}

.icon-ball {
  border: 4rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.icon-ball::before,
.icon-ball::after {
  content: '';
  position: absolute;
  background: currentColor;
  opacity: 0.95;
}

.icon-ball::before {
  left: 16rpx;
  top: 4rpx;
  width: 4rpx;
  height: 30rpx;
  transform: rotate(28deg);
}

.icon-ball::after {
  left: 5rpx;
  top: 19rpx;
  width: 28rpx;
  height: 4rpx;
  transform: rotate(-20deg);
}

.icon-cup::before {
  content: '';
  position: absolute;
  left: 11rpx;
  top: 4rpx;
  width: 20rpx;
  height: 24rpx;
  border: 4rpx solid currentColor;
  border-top-width: 6rpx;
  border-radius: 4rpx 4rpx 14rpx 14rpx;
}

.icon-cup::after {
  content: '';
  position: absolute;
  left: 18rpx;
  top: 30rpx;
  width: 7rpx;
  height: 10rpx;
  background: currentColor;
  box-shadow: -12rpx -18rpx 0 -7rpx transparent, 12rpx -18rpx 0 -7rpx transparent;
}

.icon-cup .icon-inner {
  position: absolute;
  left: 7rpx;
  bottom: 0;
  width: 28rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 5rpx;
}

.icon-bars::before,
.icon-bars::after,
.icon-bars .icon-inner {
  content: '';
  position: absolute;
  bottom: 2rpx;
  width: 8rpx;
  border-radius: 8rpx;
  background: currentColor;
}

.icon-bars::before {
  left: 4rpx;
  height: 22rpx;
}

.icon-bars .icon-inner {
  left: 17rpx;
  height: 34rpx;
}

.icon-bars::after {
  right: 4rpx;
  height: 44rpx;
}
