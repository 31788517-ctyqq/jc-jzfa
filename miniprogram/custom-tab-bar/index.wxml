<view class="custom-tabbar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tabbar-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tabbar-icon {{item.iconClass}}">
      <view class="icon-inner"></view>
    </view>
  </view>
</view>
